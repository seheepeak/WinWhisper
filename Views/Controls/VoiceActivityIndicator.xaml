<UserControl x:Class="WinWhisper.Views.Controls.VoiceActivityIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WinWhisper.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="21">

        <StackPanel x:Name="Root" Orientation="Horizontal">
            <local:PulseBar Index="0" Margin="0,0,3,0"/>
            <local:PulseBar Index="1" Margin="0,0,3,0"/>
            <local:PulseBar Index="2"/>
        </StackPanel>

</UserControl>
