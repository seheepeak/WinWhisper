<Window x:Class="WinWhisper.Views.Windows.SettingsWindow"
        x:Name="SettingsWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinWhisper.Views.Windows"
        xmlns:controls="clr-namespace:WinWhisper.Views.Controls"
        xmlns:models="clr-namespace:WinWhisper.Models"
        xmlns:ic="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        mc:Ignorable="d"
        Title="WinWhisper Settings"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="500"
        MinWidth="700">

    <!-- Apply Fluent theme and converters -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/PresentationFramework.Fluent;component/Themes/Fluent.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value Converters -->
            <local:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <!-- Resources from ModelSelectWindow -->
             <!-- Colors -->
            <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB"/>
            <SolidColorBrush x:Key="PrimaryBlueHover" Color="#1D4ED8"/>
            <SolidColorBrush x:Key="LightBlueBg" Color="#EFF6FF"/>
            <SolidColorBrush x:Key="SelectedBg" Color="#DBEAFE"/>
            <SolidColorBrush x:Key="SoftBlueBorder" Color="#BFDBFE"/>
            <SolidColorBrush x:Key="TextMain" Color="#1E293B"/>
            <SolidColorBrush x:Key="TextSub" Color="#64748B"/>
            <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
            <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
            <SolidColorBrush x:Key="DangerBg" Color="#FEE2E2"/>

            <!-- Download Button Style (App Store "GET" style) -->
            <Style x:Key="DownloadButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="16"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#1D4ED8"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#2563EB" Opacity="0.3" BlurRadius="5" ShadowDepth="2"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Simple Delete Button Style (Gray X -> Red X) -->
            <Style x:Key="SimpleDeleteButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#94A3B8"/> <!-- Light Gray -->
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <TextBlock Text="✕" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="{StaticResource DangerRed}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Progress Bar Style (from ProgressWindow) -->
            <Style x:Key="DownloadProgressBar" TargetType="ProgressBar">
                <Setter Property="Height" Value="2"/>
                <Setter Property="Foreground" Value="#FF0078D4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid x:Name="TemplateRoot">
                                <Border x:Name="PART_Track" Background="{TemplateBinding Background}" BorderThickness="0"/>
                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" BorderThickness="0"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Item Template -->
            <DataTemplate x:Key="ModelItemTemplate">
                <Border x:Name="CardBorder"
                        CornerRadius="12"
                        Margin="0,0,0,8"
                        Cursor="Hand"
                        ClipToBounds="True">
                    
                    <!-- OpacityMask to force clipping of child elements (ProgressBar) to rounded corners -->
                    <Border.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Border Background="Black" CornerRadius="12"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                        Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.OpacityMask>
                    
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding SelectCommand}"/>
                    </Border.InputBindings>

                    <Grid>
                        <!-- Main Content with Padding -->
                        <Grid Margin="16,12" MinHeight="48">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
        
                            <!-- Info Section (Single Line) -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Model Name -->
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           FontSize="15"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Size -->
                                <TextBlock Text="{Binding Size, StringFormat=' ({0})'}"
                                           Foreground="{StaticResource TextSub}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="4,0,0,0"/>
                                
                                <!-- Checkmark -->
                                <TextBlock Text="✓"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           Foreground="{StaticResource PrimaryBlue}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
        
                            <!-- Action Section -->
                            <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                
                                <!-- Downloading State -->
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DownloadProgressText}" 
                                               Foreground="{StaticResource PrimaryBlue}"
                                               FontWeight="Medium"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                               
                                    <Button Command="{Binding CancelDownloadCommand}"
                                            ToolTip="Cancel Download"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Padding="4"
                                            Height="32"
                                            Width="32"
                                            Focusable="False"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="✕" 
                                                   FontSize="14" 
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextSub}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F0F0F0"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
        
                                <!-- Downloaded/Selected State (Delete Button only) -->
                                <!-- Visible if Downloaded AND Not Selected. Opacity handled by Triggers. -->
                                <Button Style="{StaticResource SimpleDeleteButtonStyle}"
                                        Command="{Binding RemoveCommand}"
                                        ToolTip="Delete Model"
                                        x:Name="DeleteBtn"
                                        Opacity="0"
                                        Height="32"
                                        Width="32"
                                        Focusable="False"
                                        IsHitTestVisible="False"
                                        Visibility="{Binding IsDownloadedButNotSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            
                                <!-- Download Button (Not Downloaded) -->
                                <!-- Wrapped in Grid to hide when Downloading (Combined logic: !IsDownloaded AND !IsDownloading) -->
                                <Grid Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                    <Button Content="Download"
                                            Style="{StaticResource DownloadButtonStyle}"
                                            Command="{Binding DownloadCommand}"
                                            MinWidth="80" Height="32" FontSize="13"
                                            Focusable="False"
                                            Visibility="{Binding IsDownloaded, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                </Grid>
                            </Grid>
                        </Grid>
                        
                        <!-- Progress Bar (Bottom) -->
                        <ProgressBar Style="{StaticResource DownloadProgressBar}"
                                     VerticalAlignment="Bottom"
                                     Height="2"
                                     Value="{Binding DownloadProgress}"
                                     Maximum="100"
                                     Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="Cursor" Value="Arrow"/> 

                            <Style.Triggers>
                                <!-- Downloaded State (Interactive Cursor) -->
                                <DataTrigger Binding="{Binding IsDownloaded}" Value="True">
                                    <Setter Property="Cursor" Value="Hand"/>
                                </DataTrigger>

                                <!-- Selected State -->
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SelectedBg}"/> <!-- #DBEAFE -->
                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                </DataTrigger>
                                
                                <!-- Hover State (Only for Downloaded & Not Selected) -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                        <Condition Binding="{Binding IsDownloaded}" Value="True"/>
                                        <Condition Binding="{Binding IsSelected}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="BorderBrush" Value="{StaticResource SoftBlueBorder}"/>
                                    <Setter Property="Background" Value="{StaticResource LightBlueBg}"/> <!-- #EFF6FF -->
                                </MultiDataTrigger>
                                
                                <!-- Selected AND Hover State -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSelected}" Value="True"/>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" Value="{StaticResource SelectedBg}"/> <!-- #DBEAFE -->
                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <!-- Hover Animation for Delete Button -->
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="DeleteBtn" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1"/>
                                    <BooleanAnimationUsingKeyFrames Storyboard.TargetName="DeleteBtn" Storyboard.TargetProperty="IsHitTestVisible">
                                        <DiscreteBooleanKeyFrame KeyTime="0" Value="True"/>
                                    </BooleanAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="DeleteBtn" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                    <BooleanAnimationUsingKeyFrames Storyboard.TargetName="DeleteBtn" Storyboard.TargetProperty="IsHitTestVisible">
                                        <DiscreteBooleanKeyFrame KeyTime="0" Value="False"/>
                                    </BooleanAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>
            </DataTemplate>

            <!-- Settings Card Style -->
            <Style x:Key="SettingsCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#FAFCFD"/>
                <Setter Property="BorderBrush" Value="#D8D8D8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>

            <!-- Navigation Button Style -->
            <Style x:Key="NavigationButtonStyle" TargetType="RadioButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#10000000"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#20000000"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation Panel -->
        <Border Grid.Row="0" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <!-- <RowDefinition Height="Auto"/> -->
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0"
                           Text="Settings"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="20,20,20,15"/>

                <!-- Navigation Menu -->
                <ListView x:Name="NavigationListView"
                          Grid.Row="1"
                          Margin="10,0"
                          ItemsSource="{Binding NavigationItems}"
                          SelectedItem="{Binding SelectedNavigationItem}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Image 
                                    Grid.Column="0"
                                    Source="{Binding IconPath}"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                    Width="24"
                                    Margin="0,0,8,0"/>
                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Text="{Binding Name}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Version Info (Optional) -->
                <!-- <TextBlock Grid.Row="2"
                           Text="WinWhisper v1.0"
                           Foreground="Gray"
                           FontSize="11"
                           Margin="20,0,20,20"
                           VerticalAlignment="Bottom"/> -->
            </Grid>
        </Border>

        <!-- Right Content Area -->
        <ScrollViewer Grid.Row="0" Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="20,20,20,20">
                    <!-- Recording Page -->
                    <StackPanel x:Name="RecordingPage" Visibility="{Binding IsRecordingPageVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Recording"
                                   FontSize="28"
                                   FontWeight="Light"
                                   Margin="0,0,0,24"/>

                        <!-- Activation Key Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Activation Key"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Key combination to start/stop recording"
                                               Foreground="#666"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxWidth="500"/>
                                </StackPanel>

                                <TextBox x:Name="ActivationKeyTextBox"
                                         Grid.Column="1"
                                         Text="{Binding Configuration.Recording.ActivationKey}"
                                         MinWidth="200"
                                         VerticalAlignment="Center"
                                         Margin="12,0,0,0"
                                         Padding="10,8"/>
                            </Grid>
                        </Border>

                        <!-- Recording Mode Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Recording Mode"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="How recording starts and stops"
                                               Foreground="#666"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxWidth="500"/>
                                </StackPanel>

                                <ComboBox x:Name="RecordingModeComboBox"
                                          Grid.Column="1"
                                          SelectedValue="{Binding Configuration.Recording.RecordingMode}"
                                          SelectedValuePath="Tag"
                                          MinWidth="200"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"
                                          Padding="10,8">
                                    <ComboBoxItem Content="Press to toggle" Tag="{x:Static models:RecordingMode.PressToToggle}"/>
                                    <ComboBoxItem Content="Hold to record" Tag="{x:Static models:RecordingMode.HoldToRecord}"/>
                                    <ComboBoxItem Content="Voice activity detection" Tag="{x:Static models:RecordingMode.VoiceActivityDetection}"/>
                                    <ComboBoxItem Content="Continuous" Tag="{x:Static models:RecordingMode.Continuous}"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Silence Duration Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Silence Duration"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Milliseconds of silence before stopping (for voice activity detection)"
                                               Foreground="#666"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxWidth="500"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0">
                                    <TextBlock Text="{Binding Configuration.Recording.SilenceDuration}"
                                               VerticalAlignment="Center"
                                               MinWidth="50"
                                               TextAlignment="Right"
                                               Foreground="#666"
                                               Margin="0,0,16,0"/>
                                    <Slider x:Name="SilenceDurationSlider"
                                            Minimum="100"
                                            Maximum="3000"
                                            Value="{Binding Configuration.Recording.SilenceDuration}"
                                            TickFrequency="100"
                                            IsSnapToTickEnabled="True"
                                            Width="160"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Minimum Duration Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Minimum Duration"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Recordings shorter than this are discarded (milliseconds)"
                                               Foreground="#666"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxWidth="500"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0">
                                    <TextBlock Text="{Binding Configuration.Recording.MinDuration}"
                                               VerticalAlignment="Center"
                                               MinWidth="50"
                                               TextAlignment="Right"
                                               Foreground="#666"
                                               Margin="0,0,16,0"/>
                                    <Slider x:Name="MinDurationSlider"
                                            Minimum="0"
                                            Maximum="3000"
                                            Value="{Binding Configuration.Recording.MinDuration}"
                                            TickFrequency="50"
                                            IsSnapToTickEnabled="True"
                                            Width="160"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Recording Device Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Recording Device"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Select audio input device"
                                               Foreground="#666"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxWidth="500"/>
                                </StackPanel>

                                <ComboBox x:Name="DeviceComboBox"
                                          Grid.Column="1"
                                          ItemsSource="{Binding AudioDevices}"
                                          SelectedValue="{Binding Configuration.Recording.DeviceName}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          MinWidth="200"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"
                                          Padding="10,8"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Model Page -->
                    <StackPanel x:Name="ModelPage" Visibility="{Binding IsModelPageVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Model"
                                   FontSize="28"
                                   FontWeight="Light"
                                   Margin="0,0,0,24"/>

                        <Border Background="{StaticResource LightBlueBg}"
                                BorderBrush="{StaticResource SoftBlueBorder}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,0,16"
                                Visibility="{Binding NeedsInitialSetup, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Welcome to WinWhisper!"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource PrimaryBlue}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Foreground="{StaticResource TextMain}"
                                           FontSize="13"
                                           TextWrapping="Wrap">
                                    To get started, download and select a local Whisper model below,
                                    or switch to OpenAI API mode and enter your API key.
                                    The app cannot transcribe until one of these is configured.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Transcription Method Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Transcription Method"
                                           FontWeight="SemiBold"
                                           FontSize="14" Margin="0"/>

                                <!-- Seperator -->
                                <Border BorderBrush="#D8D8D8" BorderThickness="1" Height="1" Margin="-20,20"/>

                                <RadioButton x:Name="LocalModelRadio"
                                            IsChecked="{Binding Path=Configuration.Model.Api.Enabled, Converter={StaticResource InverseBooleanConverter}}"
                                            GroupName="TranscriptionMethod"
                                            Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="Local Whisper Model"
                                                FontWeight="Medium"
                                                Margin="0,0,0,4"/>
                                        <TextBlock Text="Process transcription locally on your device"
                                                Foreground="#666"
                                                FontSize="12"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton x:Name="ApiRadio"
                                            IsChecked="{Binding Configuration.Model.Api.Enabled}"
                                            GroupName="TranscriptionMethod">
                                    <StackPanel>
                                        <TextBlock Text="OpenAI API"
                                                FontWeight="Medium"
                                                Margin="0,0,0,4"/>
                                        <TextBlock Text="Use OpenAI's cloud-based transcription service"
                                                Foreground="#666"
                                                FontSize="12"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </Border>

                        <!-- Local Model Settings Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Local Model Settings"
                                           FontWeight="SemiBold"
                                           FontSize="14"/>

                                <!-- Seperator -->
                                <Border BorderBrush="#D8D8D8" BorderThickness="1" Height="1" Margin="-20,20"/>

                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding ModelSelector.Models}"
                                                  ItemTemplate="{StaticResource ModelItemTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- API Settings Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="API Settings"
                                           FontWeight="SemiBold"
                                           FontSize="14"/>

                                <!-- Seperator -->
                                <Border BorderBrush="#D8D8D8" BorderThickness="1" Height="1" Margin="-20,20"/>

                                <!-- API Key -->
                                <StackPanel>
                                    <TextBlock Text="API Key" FontWeight="Medium" Margin="0,0,0,10"/>
                                    <TextBox x:Name="ApiKeyTextBox" Text="{Binding Configuration.Model.Api.ApiKey}"/>
                                </StackPanel>

                                <!-- Seperator -->
                                <Border BorderBrush="#D8D8D8" BorderThickness="1" Height="1" Margin="-20,20"/>

                                <!-- Model -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Model"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"/>

                                    <ComboBox Grid.Column="1"
                                              x:Name="ApiModelComboBox"
                                              Text="{Binding Configuration.Model.Api.Model}"
                                              MinWidth="200"
                                              Padding="10,8">
                                        <ComboBoxItem Content="whisper-1"/>
                                        <ComboBoxItem Content="gpt-4o-mini-transcribe"/>
                                        <ComboBoxItem Content="gpt-4o-transcribe"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Seperator -->
                                <Border BorderBrush="#D8D8D8" BorderThickness="1" Height="1" Margin="-20,20"/>

                                <!-- Base URL -->
                                <StackPanel>
                                    <TextBlock Text="Base URL (Optional)"
                                                FontWeight="Medium"
                                                Margin="0,0,0,4"/>
                                    <TextBlock Text="Custom API endpoint for private servers"
                                                Foreground="#666"
                                                FontSize="12"
                                                Margin="0,0,0,10"/>
                                    <TextBox x:Name="BaseUrlTextBox" Text="{Binding Configuration.Model.Api.BaseUrl}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Post-Processing Page -->
                    <StackPanel x:Name="PostProcessingPage" Visibility="{Binding IsPostProcessingPageVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Post-Processing"
                                   FontSize="28"
                                   FontWeight="Light"
                                   Margin="0,0,0,24"/>

                        <!-- Trim Whitespace Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Trim Whitespace"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Remove leading and trailing whitespace from transcription results"
                                               Foreground="#666"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxWidth="500"/>
                                </StackPanel>

                                <controls:ToggleSwitch x:Name="TrimWhitespaceCheckBox"
                                                    Grid.Column="1"
                                                    IsChecked="{Binding Configuration.PostProcessing.TrimWhitespace}"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Input Method Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Input Method"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="How transcribed text is inserted into applications"
                                               Foreground="#666"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxWidth="500"/>
                                </StackPanel>

                                <ComboBox x:Name="InputMethodComboBox"
                                          Grid.Column="1"
                                          SelectedValue="{Binding Configuration.PostProcessing.InputMethod}"
                                          SelectedValuePath="Tag"
                                          MinWidth="200"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"
                                          Padding="10,8">
                                    <ComboBoxItem Content="Simulate Keyboard Input" Tag="{x:Static models:InputMethod.Keyboard}"/>
                                    <ComboBoxItem Content="Clipboard Paste (Ctrl+V)" Tag="{x:Static models:InputMethod.Paste}"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Key Press Delay Card -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Key Press Delay"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Delay between simulated key presses (milliseconds)"
                                               Foreground="#666"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               MaxWidth="500"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0">
                                    <TextBlock Text="{Binding Configuration.PostProcessing.WritingKeyPressDelayMs}"
                                               VerticalAlignment="Center"
                                               MinWidth="50"
                                               TextAlignment="Right"
                                               Foreground="#666"
                                               Margin="0,0,16,0"/>
                                    <Slider x:Name="KeyPressDelaySlider"
                                            Minimum="0"
                                            Maximum="100"
                                            Value="{Binding Configuration.PostProcessing.WritingKeyPressDelayMs}"
                                            Width="160"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                BorderBrush="#E0E0E0"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="40,15">
                <Button x:Name="ApplyButton"
                        Content="Apply"
                        Width="100"
                        Height="32"
                        Margin="0,0,10,0"
                        Padding="15,0"
                        Command="{Binding ApplyCommand}"
                        FontWeight="Medium"/>
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Width="100"
                        Height="32"
                        Padding="15,0"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>