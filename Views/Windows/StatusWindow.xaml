<Window x:Class="WinWhisper.Views.Windows.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinWhisper.Views.Windows"
        xmlns:controls="clr-namespace:WinWhisper.Views.Controls"
        mc:Ignorable="d"
        Title="WinWhisper" Height="100" Width="340"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SourceInitialized="StatusWindow_SourceInitialized"
        Loaded="StatusWindow_Loaded"
        Closing="StatusWindow_Closing">

    <Window.Resources>
        <Storyboard x:Key="ShowAnimation">
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleX"
                From="0.8"
                To="1.0"
                Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <BounceEase EasingMode="EaseOut" Bounces="1" Bounciness="3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleY"
                From="0.8"
                To="1.0"
                Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <BounceEase EasingMode="EaseOut" Bounces="1" Bounciness="3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="LeadingIconAnimation">
            <DoubleAnimation
                Storyboard.TargetName="LeadingIconScale"
                Storyboard.TargetProperty="ScaleX"
                Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetName="LeadingIconScale"
                Storyboard.TargetProperty="ScaleY"
                Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
        </Grid.RenderTransform>

        <Border CornerRadius="16" Margin="20" Background="#F9DD00">
            <Border.Effect>
                <DropShadowEffect Color="#F9DD00"
                            ShadowDepth="0"
                            BlurRadius="20"
                            Opacity="0.5"/>
            </Border.Effect>
        </Border>

        <controls:ProgressFill x:Name="ProgressFill"/>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid Height="32" Width="32" Margin="0,0,16,0">
                <controls:VoiceActivityIndicator
                    x:Name="VAIndicator"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"
                    IsVisibleChanged="VAIndicator_IsVisibleChanged"
                    />
                <Image x:Name="LeadingIcon"
                    Source="/Assets/Images/microphone.png"
                    RenderOptions.BitmapScalingMode="HighQuality"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <ScaleTransform x:Name="LeadingIconScale" ScaleX="1" ScaleY="1"/>
                    </Image.RenderTransform>
                </Image>
            </Grid>
            <TextBlock x:Name="StatusText" Text="abc..."
                       Foreground="#1A1A1A"
                       FontFamily="Malgun Gothic"
                       FontWeight="Bold"
                       FontSize="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>


</Window>
